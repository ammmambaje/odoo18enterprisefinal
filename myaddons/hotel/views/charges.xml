<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="view_hotel_charges_list">
    <field name="name">Charges/Accounts Master List</field>
    <field name="model">hotel.charges</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="description"/>      
        <field name="paymentaccount"/>        
      </list>
    </field>
  </record>

    <!-- explicit form view definition -->
  <record model="ir.ui.view" id="view_hotel_charges_form">
    <field name="name">Hotel Charge</field>
    <field name="model">hotel.charges</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
        <group>
          <field name="name"/>
        </group>
        <group>
          <field name="description"/>      
        </group>
        <group>
          <field name="paymentaccount"/>      
        </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- actions opening views on models -->
  <record model="ir.actions.act_window" id="action_hotel_charges">
    <field name="name">Hotel Charges and Accounts</field>
    <field name="res_model">hotel.charges</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- menu item for charges cruds -->
  <menuitem 
    name="Charges and Accounts" id="menu_hotel_charges" 
    parent="menu_hotel_masterlists"
    action="action_hotel_charges" 
    sequence="4"/>

  <!-- Daily Charges Views -->
  <record model="ir.ui.view" id="view_hotel_dailycharges_list">
    <field name="name">Daily Charges List</field>
    <field name="model">hotel.dailycharges</field>
    <field name="arch" type="xml">
      <list>
        <field name="charge_id"/>
        <field name="amount"/>
        <field name="roomtype_id"/>
      </list>
    </field>
  </record>

  <record model="ir.ui.view" id="view_hotel_dailycharges_form">
    <field name="name">Daily Charge</field>
    <field name="model">hotel.dailycharges</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="charge_id"/>
            <field name="amount"/>
            <field name="roomtype_id"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record model="ir.actions.act_window" id="action_hotel_dailycharges">
    <field name="name">Daily Charges</field>
    <field name="res_model">hotel.dailycharges</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem name="Daily Charges" id="menu_hotel_dailycharges" parent="menu_hotel_masterlists" action="action_hotel_dailycharges" sequence="5"/>
</odoo>